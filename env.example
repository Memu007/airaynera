# ===== CONFIGURACIÓN DE ENTORNO - AIRA =====
# Copiar este archivo como .env y completar con valores reales

# === SEGURIDAD ===
# JWT Secret - Generar con: openssl rand -base64 32
# NUNCA pasar secretos por CLI. Siempre usar archivo .env:
# source .env && node server-demo-funcional.js
JWT_SECRET=your-super-secret-jwt-key-change-this
SESSION_SECRET=your-session-secret-change-this

# === GOOGLE CLOUD ===
# Proyecto de Google Cloud
GOOGLE_CLOUD_PROJECT_ID=your-project-id
# Tiempo de expiración del JWT (dev: 24h, staging: 4h, prod: 1h)
JWT_EXPIRES_IN=2h

# === MERCADOPAGO (Argentina) ===
MP_ACCESS_TOKEN=TEST-your-mercadopago-access-token
MP_PUBLIC_KEY=TEST-your-mercadopago-public-key
MP_WEBHOOK_SECRET=your-webhook-secret

# Credenciales de servicio (ruta al archivo JSON)
GOOGLE_APPLICATION_CREDENTIALS=./path/to/service-account-key.json

# === GOOGLE AI ===
# API Key de Gemini
GEMINI_API_KEY=your-gemini-api-key

# === SERVIDOR ===
# Puerto del servidor
PORT=8082

# Entorno (development, staging, production)
NODE_ENV=development

# Nivel de logs (error, warn, info, debug)
LOG_LEVEL=info

# === CORS ===
# Orígenes permitidos (separados por coma)
ALLOWED_ORIGINS=http://localhost:8082,http://127.0.0.1:8082

# IPs confiables para skip de rate limiting (desarrollo)
TRUSTED_IPS=127.0.0.1,::1

# === WHATSAPP BUSINESS API ===
# Token de acceso de WhatsApp Business
WHATSAPP_ACCESS_TOKEN=your-whatsapp-token

# ID del número de teléfono de WhatsApp Business
WHATSAPP_PHONE_NUMBER_ID=your-phone-id

# Webhook verify token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-verify-token

# === EMAILS ===
# Configuración SMTP para notificaciones
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=AIRA Bot <noreply@aira-app.com>

# === BACKUPS ===
# Bucket de Google Cloud Storage para backups
BACKUP_BUCKET=your-backup-bucket

# === MONITOREO ===
# Sentry DSN para error tracking
SENTRY_DSN=your-sentry-dsn

# === PAGOS ===
# Mercado Pago (para Argentina)
MERCADOPAGO_ACCESS_TOKEN=your-mp-access-token

# === FEATURE FLAGS ===
# Activar/desactivar características
ENABLE_WHATSAPP=false
ENABLE_ANALYTICS=true
ENABLE_BACKUPS=true
ENABLE_2FA=false

# === LÍMITES ===
# Límites de uso
MAX_PATIENTS_PER_USER=100
MAX_SESSIONS_PER_DAY=50
MAX_FILE_SIZE_MB=10

# === COMPLIANCE ===
# Configuración para cumplimiento HIPAA
HIPAA_MODE=true
DATA_RETENTION_DAYS=2555  # 7 años
AUDIT_LOG_ENABLED=true

# === DESARROLLO ===
# Modo mock (sin conexiones reales)
MOCK_MODE=false
DEBUG_SQL=false 

# === DEMO SERVER (OPCIONAL) ===
# Persistencia JSON cifrada
USE_PERSISTENCE=false
# Clave de cifrado de datos (32 bytes en hex o base64)
DATA_KEY=
# Requerir JWT para APIs demo - CRITICAL: MUST BE TRUE FOR HIPAA COMPLIANCE
REQUIRE_AUTH=true
# SQLite opcional (requiere instalar better-sqlite3)
USE_SQLITE=false
# Directorio de datos (JSON/SQLite)
DATA_DIR=./data
# CSP strict o relaxed
CSP_MODE=strict
# Forzar HTTPS detrás de proxy (prod)
REQUIRE_HTTPS=false
# Límite de tamaño JSON
JSON_LIMIT=256kb
# Mantenimiento (bloquea escritura con 503)
MAINTENANCE=false
# CORS orígenes permitidos (coma)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
# Retención de backups (días)
BACKUP_RETENTION_DAYS=7
# Clave para cifrado opcional de backups
BACKUP_ENCRYPTION_KEY=

# === LOGS ===
# Activar/desactivar logging de requests (para stress tests)
REQUEST_LOGGING=true

# === RATE LIMITS ===
# Rate limit global
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
# Rate limit del endpoint de emisión de token
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=30

# === CORS EXTRA ===
# Regex opcional de CORS (por ejemplo: ^https:\/\/.*\.mi-dominio\.com$)
# IMPORTANTE: Siempre anclar con ^ y $ para evitar bypass de seguridad
CORS_ORIGINS_REGEX=^https:\/\/app\.example\.com$

# === CACHE TTLs ===
PATIENTS_CACHE_TTL_MS=2000
SESSIONS_CACHE_TTL_MS=2000

# === HEALTH ===
# Ventana y umbral para degradar /health según 5xx
HEALTH_ERROR_WINDOW_MS=60000
HEALTH_5XX_THRESHOLD=5

# === CLUSTER ===
# Workers del cluster (1 = desactivado)
CLUSTER_WORKERS=1

# === TEST ROUTES (sólo staging/desarrollo) ===
ALLOW_TEST_ROUTES=false
# Workers del cluster (1 = desactivado)
CLUSTER_WORKERS=1

# === TEST ROUTES (sólo staging/desarrollo) ===
ALLOW_TEST_ROUTES=false
# Workers del cluster (1 = desactivado)
CLUSTER_WORKERS=1

# === TEST ROUTES (sólo staging/desarrollo) ===
ALLOW_TEST_ROUTES=false