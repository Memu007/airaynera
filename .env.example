# ================================================
# AIRA MEDICAL SYSTEM - SECURE CONFIGURATION TEMPLATE
# ================================================
# SECURITY NOTICE: NEVER commit actual secrets to version control
# Generate unique values for EVERY deployment environment
# Use the provided generation commands for maximum security

# ================================================
# SERVER CONFIGURATION
# ================================================
PORT=3000
NODE_ENV=development

# ================================================
# SECURITY - CRITICAL CONFIGURATION
# ================================================
# ⚠️ CRITICAL: Authentication is now REQUIRED by default
REQUIRE_AUTH=true

# JWT Configuration (REQUIRED - no fallbacks)
# Generate secure secrets: openssl rand -base64 64
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=24h

# Encryption Configuration
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=

# Security Salts (generate unique for each deployment)
# Generate with: openssl rand -base64 32
MASTER_KEY=
PIN_PEPPER=
LOG_SALT=

# ================================================
# DATABASE CONFIGURATION
# ================================================
# Firebase/Google Cloud Configuration
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=./path/to/service-account-key.json

# SQLite (alternative database)
USE_SQLITE=false
DB_PATH=./data/aira.db

# ================================================
# EXTERNAL API SERVICES
# ================================================

# WhatsApp Business API
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=

# Enable WhatsApp features
ENABLE_WHATSAPP_WEBHOOK=false
ENABLE_WHATSAPP_INGEST=false

# Google Gemini AI
GEMINI_API_KEY=
GEMINI_BACKUP_KEY=

# OpenAI (for audio transcription)
OPENAI_API_KEY=

# MercadoPago (payment processing)
MP_ACCESS_TOKEN=
ENABLE_MP=false

# ================================================
# SECURITY HEADERS & PROTECTION
# ================================================

# HTTPS Enforcement (recommended for production)
REQUIRE_HTTPS=false

# CORS Configuration (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Content Security Policy mode: strict | relaxed
CSP_MODE=strict

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Authentication Rate Limiting (stricter)
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=20

# ================================================
# MONITORING & LOGGING
# ================================================

# Enable monitoring features
ENABLE_PERFORMANCE_MONITORING=true
MONITORING_INTERVAL=30000

# Log level: error | warn | info | debug
LOG_LEVEL=info

# Allowed IPs for admin operations (comma-separated)
ALLOWED_IPS=127.0.0.1,::1

# ================================================
# DEVELOPMENT & TESTING
# ================================================

# Enable test routes (DANGEROUS - NEVER enable in production)
ALLOW_TEST_ROUTES=false

# Test credentials (for automated testing only)
TEST_PASSWORD=

# ================================================
# GENERATION COMMANDS
# ================================================

# Generate all required secrets:
# openssl rand -base64 64  # For JWT secrets
# openssl rand -base64 32  # For encryption keys and salts

# SECURITY REMINDER:
# 1. NEVER use default values in production
# 2. Generate UNIQUE values for each environment
# 3. Rotate secrets regularly
# 4. Store secrets securely (environment variables, secret manager)
# 5. Monitor for unauthorized access attempts

