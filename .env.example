# ================================================
# AIRA MEDICAL - Configuración
# ================================================

# Servidor
PORT=3000
NODE_ENV=development
WHATSAPP_ADAPTER=fake
AUDIO_TRANSCRIBER=fake
NOTE_CLEANER=fake
APP_TIME_ZONE=America/Argentina/Buenos_Aires
AUDIO_PROCESSING_LEASE_MS=300000
AUDIO_JOB_LEASE_MS=300000
AUDIO_WORKER_POLL_MS=500
AUDIO_UPLOAD_DIR=./data/audio-uploads
AUDIO_UPLOAD_MAX_BYTES=26214400
AUDIO_UPLOAD_RETENTION_MS=86400000

# Transcripción real con Gemini (activar después de validar el benchmark)
# AUDIO_TRANSCRIBER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_REQUEST_TIMEOUT_MS=180000
GEMINI_MAX_RETRIES=2
GEMINI_FILE_READY_TIMEOUT_MS=60000

# JWT (generar con: openssl rand -base64 64)
JWT_SECRET=cambiar-este-secreto-en-produccion

# Cifrado de datos sensibles (generar con: openssl rand -hex 32)
DATA_KEY=

# Directorio de datos
DATA_DIR=./data

# n8n Service Token (para integración WhatsApp)
N8N_SERVICE_TOKEN=

# ================================================
# PRODUCCIÓN - Agregar estas variables
# ================================================
# NODE_ENV=production
# REQUIRE_HTTPS=true
# TRUSTED_ORIGINS=https://tudominio.com
