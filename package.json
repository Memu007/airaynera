{
  "name": "aira-medical-frontend",
  "version": "2.0.0",
  "description": "AIRA Medical System - Frontend Server v2.0",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "npm run test:migrations && npm run test:functional",
    "test:migrations": "node scripts/migration-tests.js",
    "test:functional": "node scripts/run-functional-tests.js",
    "test:functional:direct": "node scripts/functional-tests.js",
    "test:security": "node scripts/security-tests.js",
    "test:load": "node scripts/load-test.js smoke",
    "build": "echo \"Frontend build completed\"",
    "lint": "echo \"Linting frontend files...\"",
    "security:validate": "node scripts/security-validation.js",
    "security:test": "node scripts/security-test-suite.js --all",
    "security:hipaa": "node scripts/hipaa-compliance-report.js --validate",
    "security:breach-detect": "node scripts/hipaa-compliance-report.js --breach-detection",
    "security:rotate-secrets": "node scripts/secure-key-rotation.js --rotate-all",
    "security:backup": "node scripts/secure-key-rotation.js --backup",
    "security:encrypt-phi": "node scripts/phi-encryption-migration.js",
    "security:verify-encryption": "node scripts/test-phi-encryption.js",
    "security:audit": "node scripts/security-validation.js && node scripts/security-test-suite.js --all && node scripts/hipaa-compliance-report.js --validate",
    "security:incident-drill": "node scripts/run-incident-drill.js",
    "security:compliance-report": "node scripts/hipaa-compliance-report.js",
    "security:check-deployment": "npm run security:validate && npm run security:test && npm run security:hipaa",
    "deploy:secure": "npm run security:check-deployment && npm run build && npm start",
    "deploy:production": "NODE_ENV=production npm run security:check-deployment && npm run build && npm start",
    "deploy:validate": "npm run security:check-deployment",
    "logs:security": "tail -f ./logs/security.log",
    "logs:audit": "tail -f ./logs/audit.log",
    "logs:compliance": "tail -f ./logs/compliance.log",
    "logs:all": "tail -f ./logs/combined.log",
    "backup:create": "node scripts/backup-data.js",
    "backup:verify": "node scripts/backup-verify.js",
    "backup:restore": "node scripts/restore-data.js",
    "monitor:health": "node scripts/monitor-health.js",
    "monitor:security": "node scripts/monitor-security-events.js",
    "monitor:compliance": "node scripts/monitor-compliance.js"
  },
  "keywords": [
    "medical",
    "healthcare",
    "psychology",
    "psychiatry",
    "hipaa",
    "modular-architecture",
    "accessibility",
    "frontend"
  ],
  "author": "AIRA Medical Development Team",
  "license": "UNLICENSED",
  "dependencies": {
    "@google-cloud/firestore": "^7.11.6",
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.12.2",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.4.6",
    "celebrate": "^15.0.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.3.0",
    "helmet": "^7.1.0",
    "joi": "^18.0.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.19.2",
    "multer": "^2.0.2",
    "node-fetch": "^3.3.2",
    "socket.io": "^4.8.1",
    "winston": "^3.18.3"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/aira-medical/frontend.git"
  },
  "bugs": {
    "url": "https://github.com/aira-medical/frontend/issues"
  },
  "homepage": "https://aira-medical.com",
  "funding": {
    "type": "company",
    "url": "https://aira-medical.com/funding"
  }
}
