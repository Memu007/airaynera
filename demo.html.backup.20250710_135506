    <script>
        // Datos simulados para la demo
        const MOCKED_PATIENTS = [
            { id: 1, name: 'María Fernández', dni: '45678901', age: 45, gender: 'F', lastVisit: '2023-10-15' },
            { id: 2, name: 'Carlos López', dni: '35467890', age: 62, gender: 'M', lastVisit: '2023-10-10' },
            { id: 3, name: 'Ana Martínez', dni: '40123456', age: 34, gender: 'F', lastVisit: '2023-10-05' },
            { id: 4, name: 'Juan Pérez', dni: '28987654', age: 56, gender: 'M', lastVisit: '2023-09-28' },
            { id: 5, name: 'Laura Gómez', dni: '37123456', age: 29, gender: 'F', lastVisit: '2023-09-20' }
        ];

        // Estado de la aplicación
        const appState = {
            currentUser: null,
            currentPatient: null,
            isProcessing: false,
            conversationHistory: []
        };

        // Inicialización de la aplicación
        document.addEventListener('DOMContentLoaded', function() {
            checkAuthState();
            updateCurrentTime();
            setInterval(updateCurrentTime, 60000); // Actualizar cada minuto
        });

        // Verificar estado de autenticación
        function checkAuthState() {
            const isAuthenticated = localStorage.getItem('isAuthenticated') === 'true';
            const loginModal = document.getElementById('loginModal');
            const appContainer = document.querySelector('.app-container');

            if (isAuthenticated) {
                const username = localStorage.getItem('username') || 'Usuario';
                appState.currentUser = { username };
                loginModal.style.display = 'none';
                appContainer.style.display = 'block';
                showWelcomeMessage(username);
            } else {
                loginModal.style.display = 'flex';
                appContainer.style.display = 'none';
            }
        }

        // Manejar inicio de sesión
        function handleLogin() {
            const username = document.getElementById('username').value.trim();
            const password = document.getElementById('password').value;
            const errorElement = document.getElementById('loginError');

            // Validación simple
            if (!username || !password) {
                showError('Por favor complete todos los campos');
                return;
            }

            // Simular validación de credenciales
            setTimeout(() => {
                // Guardar estado de autenticación
                localStorage.setItem('isAuthenticated', 'true');
                localStorage.setItem('username', username);
                
                // Actualizar estado y UI
                appState.currentUser = { username };
                document.getElementById('loginModal').style.display = 'none';
                document.querySelector('.app-container').style.display = 'block';
                
                // Mostrar mensaje de bienvenida
                showWelcomeMessage(username);
            }, 800);
        }

        // Mostrar mensaje de bienvenida
        function showWelcomeMessage(username) {
            addMessage('Sistema', `¡Hola, ${username}! Soy AIRA, tu asistente médico virtual. ¿En qué puedo ayudarte hoy?`, 'system');
            
            // Mostrar opciones iniciales después de un breve retraso
            setTimeout(() => {
                showQuickReplies([
                    { text: 'Ver lista de pacientes', action: 'showPatients' },
                    { text: 'Nueva consulta', action: 'newConsultation' },
                    { text: 'Mis tareas pendientes', action: 'showTasks' }
                ]);
            }, 1000);
        }

        // Mostrar mensaje de error
        function showError(message) {
            const errorElement = document.getElementById('loginError');
            errorElement.textContent = message;
            errorElement.style.display = 'block';
            
            // Ocultar después de 5 segundos
            setTimeout(() => {
                errorElement.style.display = 'none';
            }, 5000);
        }

        // Actualizar hora actual
        function updateCurrentTime() {
            const now = new Date();
            const timeString = now.toLocaleTimeString('es-AR', { hour: '2-digit', minute: '2-digit' });
            document.getElementById('currentTime').textContent = timeString;
        }

        // Agregar mensaje al chat
        function addMessage(sender, text, type = 'user') {
            const messagesContainer = document.getElementById('messagesContainer');
            const messageElement = document.createElement('div');
            messageElement.className = `message ${type}`;
            
            const messageContent = `
                <div class="message-sender">${sender}</div>
                <div class="message-text">${text}</div>
                <div class="message-time">${new Date().toLocaleTimeString('es-AR', {hour: '2-digit', minute:'2-digit'})}</div>
            `;
            
            messageElement.innerHTML = messageContent;
            messagesContainer.appendChild(messageElement);
            messagesContainer.scrollTop = messagesContainer.scrollHeight;
            
            // Guardar en historial
            appState.conversationHistory.push({ sender, text, type, timestamp: new Date() });
        }

        // Método para mostrar respuestas rápidas
        function showQuickReplies(replies) {
            const container = document.getElementById('quickReplies');
            if (!container) return;
            
            container.innerHTML = '';
            
            if (replies && Array.isArray(replies)) {
                replies.forEach(reply => {
                    if (reply && reply.text && reply.action) {
                        const button = document.createElement('button');
                        button.className = `quick-reply ${reply.type || 'default'}`;
                        button.textContent = reply.text;
                        button.onclick = () => handleQuickReply(reply.action);
                        container.appendChild(button);
                    }
                });
            }
            
            container.style.display = 'flex';
        }

        // Manejar respuesta rápida
        function handleQuickReply(action) {
            const quickReplies = document.getElementById('quickReplies');
            quickReplies.style.display = 'none';
            
            switch(action) {
                case 'showPatients':
                    showPatientList();
                    break;
                case 'newConsultation':
                    startNewConsultation();
                    break;
                case 'showTasks':
                    showTasks();
                    break;
                default:
                    addMessage('Tú', document.querySelector(`[data-action="${action}"]`).textContent, 'user');
                    simulateBotResponse(action);
            }
        }

        // Mostrar lista de pacientes
        function showPatientList() {
            addMessage('Tú', 'Mostrar lista de pacientes', 'user');
            
            setTimeout(() => {
                addMessage('AIRABot', 'Aquí tienes la lista de tus pacientes:', 'system');
                
                const patientList = document.createElement('div');
                patientList.className = 'patient-list';
                
                MOCKED_PATIENTS.forEach(patient => {
                    const patientElement = document.createElement('div');
                    patientElement.className = 'patient-item';
                    patientElement.innerHTML = `
                        <div class="patient-name">${patient.name}</div>
                        <div class="patient-details">
                            <span>DNI: ${patient.dni}</span>
                            <span>${patient.age} años</span>
                            <span>Última visita: ${patient.lastVisit}</span>
                        </div>
                        <button class="btn-view" onclick="viewPatient(${patient.id})">Ver</button>
                    `;
                    patientList.appendChild(patientElement);
                });
                
                const messagesContainer = document.getElementById('messagesContainer');
                messagesContainer.appendChild(patientList);
                messagesContainer.scrollTop = messagesContainer.scrollHeight;
            }, 800);
        }

        // Ver detalles de un paciente
        function viewPatient(patientId) {
            const patient = MOCKED_PATIENTS.find(p => p.id === patientId);
            if (!patient) return;
            
            addMessage('Tú', `Ver detalles de ${patient.name}`, 'user');
            
            setTimeout(() => {
                const patientInfo = document.createElement('div');
                patientInfo.className = 'patient-details-card';
                patientInfo.innerHTML = `
                    <h3>${patient.name}</h3>
                    <div class="detail-row">
                        <span class="label">DNI:</span>
                        <span>${patient.dni}</span>
                    </div>
                    <div class="detail-row">
                        <span class="label">Edad:</span>
                        <span>${patient.age} años</span>
                    </div>
                    <div class="detail-row">
                        <span class="label">Género:</span>
                        <span>${patient.gender === 'M' ? 'Masculino' : 'Femenino'}</span>
                    </div>
                    <div class="detail-row">
                        <span class="label">Última visita:</span>
                        <span>${patient.lastVisit}</span>
                    </div>
                    <div class="patient-actions">
                        <button class="btn-primary" onclick="startConsultation(${patient.id})">Iniciar consulta</button>
                        <button class="btn-secondary" onclick="showPatientHistory(${patient.id})">Ver historial</button>
                    </div>
                `;
                
                const messagesContainer = document.getElementById('messagesContainer');
                messagesContainer.appendChild(patientInfo);
                messagesContainer.scrollTop = messagesContainer.scrollHeight;
            }, 800);
        }

        // Iniciar nueva consulta
        function startNewConsultation() {
            addMessage('Tú', 'Nueva consulta', 'user');
            
            setTimeout(() => {
                addMessage('AIRABot', 'Por favor, ingresa el DNI o nombre del paciente:', 'system');
                
                // Mostrar teclado numérico para DNI
                const inputContainer = document.createElement('div');
                inputContainer.className = 'dni-input-container';
                inputContainer.innerHTML = `
                    <input type="text" id="patientSearch" placeholder="DNI o nombre" class="dni-input">
                    <button class="btn-primary" onclick="searchPatient()">Buscar</button>
                `;
                
                const messagesContainer = document.getElementById('messagesContainer');
                messagesContainer.appendChild(inputContainer);
                messagesContainer.scrollTop = messagesContainer.scrollHeight;
                
                // Enfocar el input
                document.getElementById('patientSearch').focus();
            }, 800);
        }

        // Buscar paciente
        function searchPatient() {
            const searchTerm = document.getElementById('patientSearch').value.trim();
            if (!searchTerm) return;
            
            addMessage('Tú', searchTerm, 'user');
            
            // Eliminar el input de búsqueda
            const inputContainer = document.querySelector('.dni-input-container');
            if (inputContainer) inputContainer.remove();
            
            // Simular búsqueda
            setTimeout(() => {
                const foundPatient = MOCKED_PATIENTS.find(p => 
                    p.dni.includes(searchTerm) || 
                    p.name.toLowerCase().includes(searchTerm.toLowerCase())
                );
                
                if (foundPatient) {
                    viewPatient(foundPatient.id);
                } else {
                    addMessage('AIRABot', 'No se encontró ningún paciente con esos datos. ¿Deseas intentar con otro criterio de búsqueda?', 'system');
                    startNewConsultation();
                }
            }, 1000);
        }

        // Iniciar consulta con paciente
        function startConsultation(patientId) {
            const patient = MOCKED_PATIENTS.find(p => p.id === patientId);
            if (!patient) return;
            
            appState.currentPatient = patient;
            
            // Limpiar mensajes anteriores
            const messagesContainer = document.getElementById('messagesContainer');
            messagesContainer.innerHTML = '';
            
            // Mostrar encabezado de consulta
            const header = document.createElement('div');
            header.className = 'consultation-header';
            header.innerHTML = `
                <h3>Consulta con ${patient.name}</h3>
                <div class="patient-info">
                    <span>DNI: ${patient.dni}</span>
                    <span>${patient.age} años</span>
                </div>
            `;
            messagesContainer.appendChild(header);
            
            // Mostrar mensaje de inicio
            addMessage('AIRABot', `Hola, soy AIRA. Estoy listo para ayudarte con la consulta de ${patient.name}. ¿En qué puedo asistirte hoy?`, 'system');
            
            // Mostrar opciones de consulta
            setTimeout(() => {
                showQuickReplies([
