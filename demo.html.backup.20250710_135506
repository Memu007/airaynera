                this.updateBreadcrumbs();
                this.updateStateIndicator();
                
                this.log('Bot reiniciado');
            
            
            getStats() {
                
                    ...this.stats,
                    currentState: this.state,
                    currentPatient: this.currentPatient?.nombre || 'Ninguno',
                    totalPatients: this.patients.length,
                    totalSessions: this.sessions.length
                };
            
        
        
        let bot = null;
        
        function initializeBot() {
            bot = new AIRABot();
            
            setTimeout(() => {
                bot.addMessage('¡Hola Dr. González! 👋 Bienvenido a AIRA Bot.\n\nSoy tu asistente para carga de datos clínicos con Google Gemini 1.5. ¿En qué te puedo ayudar hoy?', 'bot');
                bot.showQuickReplies([
                    {text: '👥 Gestionar pacientes', type: 'primary', action: 'manage_patients',
                    {text: '📝 Nueva sesión', type: 'primary', action: 'new_session',
                    {text: '📊 Historial', type: 'secondary', action: 'view_history',
                    {text: '🆘 Ayuda', type: 'secondary', action: 'help'
                ]);
            , 500);
        
        
        function sendMessage() {
            const input = document.getElementById('messageInput');
            const message = input.value.trim();
            
            if (!message || bot.isProcessing) return;
            
            bot.addMessage(message, 'user');
            input.value = '';
            
            bot.processMessage(message);
        
        
        function handleKeyPress(event) {
            if (event.key === 'Enter' && !event.shiftKey) {
                event.preventDefault();
                sendMessage();
            
        
        
        function toggleMicrophone() {
            if (bot.isRecording) return;
            
            const micBtn = document.getElementById('micBtn');
            micBtn.classList.add('recording');
            bot.isRecording = true;
            
            setTimeout(() => {
                micBtn.classList.remove('recording');
                bot.isRecording = false;
                bot.simulateMicrophone();
            , 1500);
        
        
        function resetBot() {
            bot.reset();
            setTimeout(() => {
                initializeBot();
            , 500);
        
        
        function showStats() {
            const stats = bot.getStats();
            bot.addMessage(`📊 **Estadísticas del Sistema**\n\n• Mensajes procesados: ${stats.messagesProcessed\n• Pacientes registrados: ${stats.totalPatients\n• Sesiones creadas: ${stats.totalSessions\n• Errores: ${stats.errors\n\n**Estado actual:** ${stats.currentState\n**Paciente activo:** ${stats.currentPatient`, 'bot');
        
        
        function toggleDebug() {
            bot.debugMode = !bot.debugMode;
            bot.log(`Modo debug ${bot.debugMode ? 'activado' : 'desactivado'`);
            bot.addMessage(`🐛 Modo debug ${bot.debugMode ? 'activado' : 'desactivado'`, 'bot');
        
        
        window.addEventListener('load', () => {
            console.log('🌱 AIRA Bot v2.0 - Sistema Médico con Google Gemini 1.5');
            initializeBot();
        });
        
        window.addEventListener('error', (event) => {
            console.error('Error global:', event.error);
            if (bot) {
                bot.stats.errors++;
                bot.log(`Error global: ${event.error.message`, 'error');
            
        });
    </script>
</body>
</html>