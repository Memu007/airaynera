    <script>
    // Limpiar cualquier sesión existente al cargar la página de login
    (function() {
        // Ejecutar inmediatamente, sin esperar a window.onload
        try {
            // Limpiar sessionStorage y localStorage
            sessionStorage.clear();
            localStorage.clear();
            
            // Limpiar cookies relacionadas con la sesión
            document.cookie.split(';').forEach(function(c) {
                document.cookie = c.trim().split('=')[0] + '=;expires=Thu, 01 Jan 1970 00:00:00 UTC;path=/';
            });
            
            console.log('Sesión limpiada al cargar página de login');
            
            // Verificar si venimos de /webaira o index.html
            if (document.referrer.includes('/webaira') || document.referrer.includes('/index.html')) {
                console.log('Redirigido desde dashboard, asegurando limpieza completa');
                // Forzar recarga completa para limpiar cualquier recurso cacheado
                if (performance && performance.navigation.type !== 1) { // 1 es RELOAD
                    window.location.reload(true);
                }
            }
        } catch (e) {
            console.error('Error al limpiar sesión:', e);
        }
    })();
    </script>
