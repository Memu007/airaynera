            extractDirectSessionLog(message) {
                console.log("DEBUG: Procesando mensaje para sesión directa: " + message);
                
                // 1. Formato: "Nombre, DNI - notas" (con espacios opcionales)
                const guionPattern = /^([^,]+),\s*(\d+)\s*-\s*(.+)$/;
                const guionMatch = message.match(guionPattern);
                if (guionMatch) {
                    const nombre = guionMatch[1].trim();
                    const dni = guionMatch[2];
                    const notas = guionMatch[3].trim();
                    
                    console.log('DEBUG: Formato con guion detectado:', nombre, dni, notas);
                    
                    return {
                        patientNameQuery: nombre,
                        notes: notas
                    };
                }

                // 2. Formato: "Nombre, DNI, OS, Tel - notas"
                const fullPattern = /^([^,]+),\s*(\d+),\s*([^,]+)(?:,\s*(\d+))?\s*-\s*(.+)$/;
                const fullMatch = message.match(fullPattern);
                if (fullMatch) {
                    const nombre = fullMatch[1].trim();
                    const dni = fullMatch[2];
                    const os = fullMatch[3].trim();
                    const tel = fullMatch[4];
                    const notas = fullMatch[5].trim();
                    
                    console.log('DEBUG: Formato completo detectado:', nombre, dni, os, tel, notas);
                    
                    return {
                        patientNameQuery: nombre,
                        notes: notas
                    };
                }

                // 3. Formato simple: "Nombre, DNI"
                const simplePattern = /^([^,]+),\s*(\d+)(?:\s|$)/;
                const simpleMatch = message.match(simplePattern);
                if (simpleMatch) {
                    const nombre = simpleMatch[1].trim();
                    const dni = simpleMatch[2];
                    
                    console.log('DEBUG: Formato simple detectado:', nombre, dni);
                    
                    return {
                        patientNameQuery: nombre,
                        notes: message
                    };
                }

                console.log('DEBUG: Ningún patrón coincidió');
                return null;
            }
            
