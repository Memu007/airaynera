# 🏥 AIRA Medical System - n8n-workflow-builder MCP Configuration
# Configuración para integración MCP con n8n y Gemini 2.0

# 🔐 GOOGLE GEMINI 2.0 API CONFIGURATION
GEMINI_API_KEY=AIzaSyBi-JgR5zF2J1xpC9_PuNGT0dgg7_2E1rI
GEMINI_MODEL=gemini-2.0-flash-exp
GEMINI_TEMPERATURE=0.3
GEMINI_MAX_TOKENS=8192

# 🗣️ GOOGLE SPEECH-TO-TEXT CONFIGURATION (PARA TRANSCRIPCIÓN)
GOOGLE_SPEECH_API_KEY=AIzaSyBi-JgR5zF2J1xpC9_PuNGT0dgg7_2E1rI
GOOGLE_SPEECH_LANGUAGE=es-ES
GOOGLE_SPEECH_ENCODING=WEBM_OPUS

# 📱 WHATSAPP BUSINESS API CONFIGURATION
WHATSAPP_API_VERSION=v18.0
WHATSAPP_WEBHOOK_VERIFY_TOKEN=aira_webhook_mcp_2025
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token

# 🔗 N8N CONNECTION CONFIGURATION
N8N_INSTANCE_URL=http://localhost:5678
N8N_API_KEY=your_n8n_api_key
N8N_USERNAME=aira_admin
N8N_PASSWORD=aira_secure_2025

# 🏥 AIRA MEDICAL SYSTEM API CONFIGURATION
AIRA_API_BASE_URL=http://localhost:8082
AIRA_API_SECRET=aira_optimization_secret_2025
AIRA_JWT_SECRET=aira_jwt_min_32_chars_long_2025

# 🔐 MCP SERVER CONFIGURATION
MCP_SERVER_PORT=3001
MCP_SERVER_HOST=localhost
MCP_SERVER_LOG_LEVEL=info

# 📊 SESSION PROCESSING CONFIGURATION
SESSION_MAX_AUDIO_SIZE=50000000  # 50MB
SESSION_MAX_TEXT_LENGTH=10000
SESSION_TIMEOUT=300000  # 5 minutos

# ⚠️ MODO DE USO: OPTIMIZACIÓN SOLA
MODE=session_optimization_only
NO_CLINICAL_ANALYSIS=true
NO_MEDICAL_ADVICE=true
NO_RISK_ASSESSMENT=true
NO_TREATMENT_RECOMMENDATIONS=true

# 📋 WORKFLOW TEMPLATES
WORKFLOW_TEMPLATE_PATH=./workflows
DEFAULT_WORKFLOW=aira-session-loader-optimized

# 🔄 RATE LIMITING
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_WINDOW_MS=60000

# 📝 LOGGING CONFIGURATION
ENABLE_SESSION_LOGGING=true
ENABLE_PERFORMANCE_LOGGING=true
LOG_FILE_PATH=./logs/n8n-mcp.log

# 🎯 SESSION LOADING CONFIGURATION
ENABLE_VOICE_TRANSCRIPTION=true
ENABLE_TEXT_PROCESSING=true
ENABLE_PATIENT_RECOGNITION=true
ENABLE_SESSION_CREATION=true
ENABLE_CONFIRMATION_MESSAGES=true

# 🚨 WARNINGS
WARNING=SESSION_OPTIMIZATION_ONLY_NO_CLINICAL_ANALYSIS
DISCLAIMER=Este sistema está diseñado únicamente para optimizar la carga de sesiones médicas. No proporciona análisis clínico, diagnóstico o tratamiento profesional.